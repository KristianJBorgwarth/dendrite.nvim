{
  "runtime": {
    "version": "LuaJIT"
  },
  "diagnostics": {
    "globals": [
      "describe",
      "it",
      "before_each",
      "after_each",
      "setup",
      "teardown",
      "assert"
    ]
  },
    "diagnostics.disable": [
        "need-check-nil",
        "param-type-mismatch"
    ]
}
